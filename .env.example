COMPOSE_PROJECT_NAME=ai-engineering-demo

# Public lecture demo defaults. These values are intentionally committed.
# Username/password pairs use admin/admin across the stack.
POSTGRES_DB=litellm
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
REDIS_PASSWORD=admin
LITELLM_MASTER_KEY=sk-ai-demo-local-change-me
LITELLM_SALT_KEY=sk-litellm-local-salt-change-me
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=admin
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Small default model for laptops. Replace if the lecture needs a different model.
OLLAMA_MODEL=qwen2.5:0.5b
LITELLM_OLLAMA_MODEL=ollama_chat/qwen2.5:0.5b
OLLAMA_KEEP_ALIVE=24h

# Codex lecture demo service.
CODEX_RAG_DEMO_PORT=8080
CODEX_RAG_DEMO_TOP_K=3
CODEX_RAG_DEMO_VECTOR_DIMS=32

# Local ports.
GRAFANA_PORT=3000
LITELLM_PORT=4000
OLLAMA_PORT=11434
VICTORIAMETRICS_PORT=8428
VICTORIALOGS_PORT=9428
POSTGRES_PORT=5432
REDIS_PORT=6379
VECTOR_API_PORT=8686
VECTOR_METRICS_PORT=9598
POSTGRES_EXPORTER_PORT=9187
REDIS_EXPORTER_PORT=9121

# Retention for a lecture/demo environment.
VICTORIAMETRICS_RETENTION=7d
VICTORIALOGS_RETENTION=7d
